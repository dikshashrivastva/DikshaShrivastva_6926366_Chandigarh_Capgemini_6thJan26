@{ ViewData["Title"] = "New Order"; }

<h2><i class="bi bi-cart-plus"></i> Place New Order</h2>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <div>@error.ErrorMessage</div>
        }
    </div>
}

<div class="card shadow-sm p-4">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <div class="row mb-3">
            <div class="col-md-6">
                <label class="form-label fw-bold">Customer</label>
                <select name="CustomerId" class="form-select" required>
                    <option value="">-- Select Customer --</option>
                    @foreach (var c in ViewBag.CustomerId as Microsoft.AspNetCore.Mvc.Rendering.SelectList)
                    {
                        <option value="@c.Value">@c.Text</option>
                    }
                </select>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-bold">Shipping Address</label>
                <textarea name="shippingAddress" class="form-control" rows="2" required></textarea>
            </div>
        </div>

        <h5 class="mt-3">Select Products <small class="text-muted fw-normal fs-6">(set qty to 0 to skip)</small></h5>
        <table class="table table-bordered align-middle">
            <thead class="table-secondary">
                <tr>
                    <th>Product</th>
                    <th>Category</th>
                    <th>Unit Price</th>
                    <th>Stock</th>
                    <th style="width:120px">Qty</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in ViewBag.Products as List<ECommerceOrderManagement.Models.Product>)
                {
                    <tr>
                        <td>
                            <input type="hidden" name="productIds" value="@p.ProductId" />
                            @p.Name
                        </td>
                        <td>@p.Category?.Name</td>
                        <td class="text-success fw-bold">₹@p.Price.ToString("N2")</td>
                        <td>@p.Stock</td>
                        <td>
                            <input type="number"
                                   name="quantities"
                                   value="0"
                                   min="0"
                                   max="@p.Stock"
                                   class="form-control form-control-sm text-center" />
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="mt-3">
            <button type="submit" class="btn btn-success btn-lg">
                <i class="bi bi-check-circle"></i> Place Order
            </button>
            <a asp-action="Index" class="btn btn-secondary btn-lg">Cancel</a>
        </div>
    </form>
</div>