@model HospitalMVC.Models.DepartmentViewModel
@{ ViewData["Title"] = "Edit Department"; }

<div class="page-header">
    <h2><i class="fas fa-edit me-3"></i>Edit Department</h2>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header"><i class="fas fa-building me-2"></i>Update Details</div>
            <div class="card-body p-4">
                <form asp-action="Edit" asp-route-id="@Model.DepartmentId" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                    <div class="mb-4">
                        <label asp-for="DepartmentName" class="form-label">Department Name</label>
                        <input asp-for="DepartmentName" class="form-control" />
                        <span asp-validation-for="DepartmentName" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="Description" class="form-label">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="d-flex gap-3">
                        <button type="submit" class="btn btn-primary flex-fill">
                            <i class="fas fa-save me-2"></i>Update
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>