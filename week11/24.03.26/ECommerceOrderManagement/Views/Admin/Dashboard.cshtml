@model ECommerceOrderManagement.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-speedometer2"></i> Admin Dashboard</h2>
    <a asp-action="Logout" class="btn btn-outline-danger">Logout</a>
</div>

<div class="row g-4">
    <!-- Top Products -->
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-success text-white"><i class="bi bi-trophy"></i> Top 5 Selling Products</div>
            <ul class="list-group list-group-flush">
                @foreach (var p in Model.TopProducts)
                {
                    <li class="list-group-item d-flex justify-content-between">
                        @p.ProductName
                        <span class="badge bg-success">@p.TotalSold sold</span>
                    </li>
                }
            </ul>
        </div>
    </div>

    <!-- Pending Shipments -->
    <div class="col-md-8">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-warning text-dark"><i class="bi bi-truck"></i> Pending Shipments</div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead><tr><th>Order #</th><th>Customer</th><th>Date</th><th>Total</th><th>Action</th></tr></thead>
                    <tbody>
                        @foreach (var o in Model.PendingShipments)
                        {
                            <tr>
                                <td>@o.OrderId</td>
                                <td>@o.Customer?.FullName</td>
                                <td>@o.OrderDate.ToShortDateString()</td>
                                <td>@o.TotalAmount.ToString("C")</td>
                                <td>
                                    <a asp-action="UpdateShipping" asp-route-id="@o.ShippingDetail?.ShippingDetailId"
                                       class="btn btn-sm btn-primary">Update</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Customer Summary -->
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header bg-info text-white"><i class="bi bi-people"></i> Customer Order Summary</div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead><tr><th>Customer</th><th>Email</th><th>Total Orders</th><th>Total Spent</th></tr></thead>
                    <tbody>
                        @foreach (var c in Model.CustomerSummaries)
                        {
                            <tr>
                                <td>@c.CustomerName</td>
                                <td>@c.Email</td>
                                <td>@c.TotalOrders</td>
                                <td>@c.TotalSpent.ToString("C")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>