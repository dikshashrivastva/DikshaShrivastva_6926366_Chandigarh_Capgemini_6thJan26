@model List<HospitalMVC.Models.DepartmentViewModel>
@{ ViewData["Title"] = "Departments"; }

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2><i class="fas fa-building me-3"></i>Departments</h2>
        <p>Manage hospital departments and specializations.</p>
    </div>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary btn-lg">
            <i class="fas fa-plus me-2"></i>Add Department
        </a>
    }
</div>

<div class="row g-4">
    @foreach (var dept in Model)
    {
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <div style="width:55px;height:55px;background:linear-gradient(135deg,#FFD700,#FFA500);
                            border-radius:12px;display:flex;align-items:center;justify-content:center;
                            font-size:1.5rem;color:#5D4037;margin-right:15px;">
                            <i class="fas fa-stethoscope"></i>
                        </div>
                        <div>
                            <h5 class="mb-0 fw-bold">@dept.DepartmentName</h5>
                            <small style="color:#FFA500;">
                                <i class="fas fa-user-md me-1"></i>@dept.DoctorCount Doctor(s)
                            </small>
                        </div>
                    </div>
                    <p class="text-muted mb-3">@(dept.Description ?? "No description available.")</p>
                    <div class="d-flex gap-2">
                        <a asp-controller="Doctors" asp-action="Index"
                           asp-route-departmentId="@dept.DepartmentId"
                           class="btn btn-outline-primary btn-sm flex-fill">
                            <i class="fas fa-user-md me-1"></i>View Doctors
                        </a>
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Edit" asp-route-id="@dept.DepartmentId"
                               class="btn btn-warning btn-sm">
                                <i class="fas fa-edit"></i>
                            </a>
                            <button class="btn btn-danger btn-sm"
                                    onclick="confirmDelete(@dept.DepartmentId, '@dept.DepartmentName')">
                                <i class="fas fa-trash"></i>
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content" style="border-radius:16px;">
            <div class="modal-header" style="background:linear-gradient(135deg,#FFD700,#FFA500);">
                <h5 class="modal-title fw-bold">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Are you sure you want to delete <strong id="deptName"></strong>?
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <a id="deleteLink" class="btn btn-danger">
                    <i class="fas fa-trash me-2"></i>Delete
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function confirmDelete(id, name) {
    document.getElementById('deptName').innerText = name;
    document.getElementById('deleteLink').href = '/Departments/Delete/' + id;
    new bootstrap.Modal(document.getElementById('deleteModal')).show();
}
</script>
}