@model SmartHealthcare.Models.DTOs.CreateBillDTO
@{
    ViewData["Title"] = "Create Bill";
}

<div class="container mt-4">
    <div class="card shadow" style="max-width:500px; margin:auto;">
        <div class="card-header bg-dark text-white">
            <h4>Create Bill</h4>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <input type="hidden" asp-for="AppointmentId" />

                <div class="mb-3">
                    <label class="form-label">Appointment ID</label>
                    <input class="form-control" value="@Model.AppointmentId" readonly />
                </div>

                <div class="mb-3">
                    <label asp-for="ConsultationFee" class="form-label">Consultation Fee (₹)</label>
                    <input asp-for="ConsultationFee" class="form-control" type="number" step="0.01" min="0" />
                    <span asp-validation-for="ConsultationFee" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="MedicineCharges" class="form-label">Medicine Charges (₹)</label>
                    <input asp-for="MedicineCharges" class="form-control" type="number" step="0.01" min="0" />
                    <span asp-validation-for="MedicineCharges" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Create Bill</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}