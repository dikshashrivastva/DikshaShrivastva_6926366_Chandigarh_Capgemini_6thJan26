<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EventHub</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark px-4">
        <a class="navbar-brand fw-bold fs-4" href="/">🎟️ EventHub</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link" href="/">Events</a>
                </li>
                <li class="nav-item" id="myBookingsLink" style="display:none">
                    <a class="nav-link" href="/MyBookings">My Bookings</a>
                </li>
            </ul>
            <ul class="navbar-nav ms-auto">
                <li class="nav-item" id="guestLinks">
                    <a class="nav-link" href="/Login">Login</a>
                </li>
                <li class="nav-item" id="guestRegister">
                    <a class="nav-link" href="/Register">Register</a>
                </li>
                <li class="nav-item dropdown" id="userMenu" style="display:none">
                    <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown" id="userNameDisplay"></a>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" href="/MyBookings">My Bookings</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item text-danger" href="#" onclick="logout()">Logout</a></li>
                    </ul>
                </li>
            </ul>
        </div>
    </nav>

    <main class="container my-4">
        @RenderBody()
    </main>

    <footer class="bg-dark text-white text-center py-3 mt-5">
        <p class="mb-0">Made with <i class="bi bi-heart"></i> by Diksha Shrivastva</p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        const token = localStorage.getItem('jwt_token');
        const userName = localStorage.getItem('user_name');
        if (token) {
            document.getElementById('guestLinks').style.display = 'none';
            document.getElementById('guestRegister').style.display = 'none';
            document.getElementById('userMenu').style.display = 'block';
            document.getElementById('myBookingsLink').style.display = 'block';
            document.getElementById('userNameDisplay').textContent = userName;
        }

        function logout() {
            localStorage.removeItem('jwt_token');
            localStorage.removeItem('user_name');
            localStorage.removeItem('user_email');
            window.location.href = '/';
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>