@model ECommerceOrderManagement.Models.ShippingDetail
@{
    ViewData["Title"] = "Update Shipping";
}

<h2><i class="bi bi-truck"></i> Update Shipping Details</h2>
<div class="card shadow-sm p-4" style="max-width:600px">
    <form asp-action="UpdateShipping" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ShippingDetailId" />
        <input type="hidden" asp-for="OrderId" />
        <div class="mb-3">
            <label asp-for="ShippingStatus" class="form-label"></label>
            <select asp-for="ShippingStatus" class="form-select">
                <option>Pending</option>
                <option>Shipped</option>
                <option>Delivered</option>
            </select>
        </div>
        <div class="mb-3">
            <label asp-for="TrackingNumber" class="form-label"></label>
            <input asp-for="TrackingNumber" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="ShippedDate" class="form-label"></label>
            <input asp-for="ShippedDate" type="date" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="DeliveryDate" class="form-label"></label>
            <input asp-for="DeliveryDate" type="date" class="form-control" />
        </div>
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Dashboard" class="btn btn-secondary">Cancel</a>
    </form>
</div>