@page
@model EventBooking.Web.Pages.LoginModel
@{
    ViewData["Title"] = "Login";
}

<div class="auth-card">
    <h2 class="text-center mb-4">Welcome Back 👋</h2>
    <div id="errorMsg" class="alert alert-danger d-none"></div>
    <div id="successMsg" class="alert alert-success d-none"></div>

    <div class="mb-3">
        <label class="form-label fw-semibold">Email</label>
        <input type="email" id="email" class="form-control" placeholder="you@example.com" />
    </div>
    <div class="mb-3">
        <label class="form-label fw-semibold">Password</label>
        <input type="password" id="password" class="form-control" placeholder="••••••••" />
    </div>
    <button class="btn btn-primary w-100 mt-2" onclick="loginUser()">Login</button>
    <p class="text-center mt-3 text-muted">
        Don't have an account? <a href="/Register" style="color:#e91e63">Register here</a>
    </p>
</div>