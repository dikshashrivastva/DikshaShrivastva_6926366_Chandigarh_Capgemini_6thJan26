@model IEnumerable<ECommerceOrderManagement.Models.Order>
@{
    ViewData["Title"] = "Orders";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-cart4"></i> Orders</h2>
    <a asp-action="Create" class="btn btn-success"><i class="bi bi-plus-circle"></i> New Order</a>
</div>

<table class="table table-bordered table-hover shadow-sm">
    <thead class="table-dark">
        <tr><th>Order #</th><th>Customer</th><th>Date</th><th>Total</th><th>Status</th><th>Shipping</th><th>Actions</th></tr>
    </thead>
    <tbody>
        @foreach (var o in Model)
        {
            <tr>
                <td>@o.OrderId</td>
                <td>@o.Customer?.FullName</td>
                <td>@o.OrderDate.ToShortDateString()</td>
                <td>@o.TotalAmount.ToString("C")</td>
                <td><span class="badge bg-primary">@o.Status</span></td>
                <td>@(o.ShippingDetail?.ShippingStatus ?? "N/A")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@o.OrderId" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Delete" asp-route-id="@o.OrderId" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>