@model HospitalMVC.Models.RegisterViewModel
@{ ViewData["Title"] = "Register"; Layout = null; }

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Register - MediCare</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <style>
        body {
            background: linear-gradient(135deg, #FFD700 0%, #FFA500 50%, #FF8C00 100%);
            min-height: 100vh; display: flex; align-items: center;
            justify-content: center; font-family: 'Segoe UI', sans-serif;
        }
        .register-card {
            background: #fff; border-radius: 24px; padding: 45px 40px;
            width: 100%; max-width: 480px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.2);
        }
        .logo-icon {
            width: 70px; height: 70px;
            background: linear-gradient(135deg, #FFD700, #FFA500);
            border-radius: 50%; display: flex; align-items: center;
            justify-content: center; margin: 0 auto 15px;
            font-size: 2rem; color: #5D4037;
        }
        .form-control, .form-select {
            border: 2px solid #FFE566; border-radius: 12px;
            padding: 11px 15px 11px 42px; transition: all 0.3s;
        }
        .form-control:focus, .form-select:focus {
            border-color: #FFA500; box-shadow: 0 0 0 0.2rem rgba(255,165,0,0.25);
        }
        .form-select { padding-left: 15px; }
        .input-wrapper { position: relative; }
        .input-icon { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: #FFA500; }
        .btn-register {
            background: linear-gradient(135deg, #FFD700, #FFA500);
            border: none; border-radius: 12px; padding: 13px;
            font-size: 1rem; font-weight: 700; color: #2C1810; width: 100%;
        }
        .btn-register:hover { background: linear-gradient(135deg, #FFA500, #FF8C00); transform: translateY(-2px); }
        .form-label { font-weight: 600; color: #5D4037; }
    </style>
</head>
<body>
    <div class="register-card">
        <div class="text-center mb-4">
            <div class="logo-icon mx-auto"><i class="fas fa-user-plus"></i></div>
            <h3 style="font-weight:800;color:#2C1810;">Create Account</h3>
            <p style="color:#888;font-size:0.9rem;">Join MediCare Hospital System</p>
        </div>

        <form asp-action="Register" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small"></div>

            <div class="mb-3">
                <label asp-for="FullName" class="form-label">Full Name</label>
                <div class="input-wrapper">
                    <i class="fas fa-user input-icon"></i>
                    <input asp-for="FullName" class="form-control" placeholder="John Doe" />
                </div>
                <span asp-validation-for="FullName" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email Address</label>
                <div class="input-wrapper">
                    <i class="fas fa-envelope input-icon"></i>
                    <input asp-for="Email" class="form-control" placeholder="john@email.com" />
                </div>
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label">Password</label>
                <div class="input-wrapper">
                    <i class="fas fa-lock input-icon"></i>
                    <input asp-for="Password" class="form-control" type="password" placeholder="Min 6 characters" />
                </div>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label">Confirm Password</label>
                <div class="input-wrapper">
                    <i class="fas fa-lock input-icon"></i>
                    <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="Repeat password" />
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Role" class="form-label">Register As</label>
                <select asp-for="Role" class="form-select">
                    <option value="Patient">Patient</option>
                </select>
            </div>

            <button type="submit" class="btn-register">
                <i class="fas fa-user-plus me-2"></i>Create Account
            </button>

            <div class="text-center mt-3">
                Already have an account?
                <a asp-action="Login" style="color:#FFA500;font-weight:600;text-decoration:none;">Sign In</a>
            </div>
        </form>
    </div>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
</body>
</html>