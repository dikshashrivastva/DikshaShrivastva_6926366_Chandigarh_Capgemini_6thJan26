<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MediCare Hospital</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        :root {
            --yellow-primary: #FFD700;
            --yellow-dark: #FFA500;
            --yellow-darker: #FF8C00;
            --yellow-light: #FFF8DC;
            --yellow-pale: #FFFACD;
            --yellow-medium: #FFE566;
            --brown-dark: #5D4037;
            --text-dark: #2C1810;
        }

        * { box-sizing: border-box; }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--yellow-pale);
            color: var(--text-dark);
            min-height: 100vh;
        }

        /* NAVBAR */
        .navbar {
            background: linear-gradient(135deg, #FF8C00 0%, #FFD700 50%, #FFA500 100%) !important;
            box-shadow: 0 4px 15px rgba(255,140,0,0.4);
            padding: 12px 0;
        }

        .navbar-brand {
            font-size: 1.6rem;
            font-weight: 800;
            color: var(--text-dark) !important;
            letter-spacing: 1px;
        }

        .navbar-brand i { color: #fff; margin-right: 8px; }

        .navbar-nav .nav-link {
            color: var(--text-dark) !important;
            font-weight: 600;
            padding: 8px 15px !important;
            border-radius: 8px;
            margin: 0 3px;
            transition: all 0.3s ease;
        }

        .navbar-nav .nav-link:hover {
            background-color: rgba(255,255,255,0.3);
            color: var(--brown-dark) !important;
            transform: translateY(-2px);
        }

        .navbar-toggler { border-color: var(--text-dark); }

        /* SIDEBAR */
        .sidebar {
            background: linear-gradient(180deg, #FF8C00 0%, #FFD700 100%);
            min-height: calc(100vh - 70px);
            padding: 20px 0;
            box-shadow: 4px 0 15px rgba(255,140,0,0.2);
            position: sticky;
            top: 0;
        }

        .sidebar .nav-link {
            color: var(--text-dark) !important;
            font-weight: 600;
            padding: 12px 20px;
            border-radius: 0 25px 25px 0;
            margin: 3px 10px 3px 0;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .sidebar .nav-link:hover, .sidebar .nav-link.active {
            background-color: rgba(255,255,255,0.4);
            color: var(--brown-dark) !important;
            transform: translateX(5px);
            box-shadow: 2px 2px 8px rgba(0,0,0,0.1);
        }

        .sidebar .nav-link i { width: 20px; text-align: center; }

        .sidebar-heading {
            color: var(--brown-dark);
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            padding: 10px 20px 5px;
            margin-top: 10px;
        }

        /* CARDS */
        .card {
            border: none;
            border-radius: 16px;
            box-shadow: 0 4px 20px rgba(255,165,0,0.15);
            background: #fff;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .card:hover { transform: translateY(-4px); box-shadow: 0 8px 30px rgba(255,165,0,0.25); }

        .card-header {
            background: linear-gradient(135deg, #FFD700, #FFA500);
            border-radius: 16px 16px 0 0 !important;
            color: var(--text-dark);
            font-weight: 700;
            padding: 15px 20px;
            border: none;
        }

        /* STAT CARDS */
        .stat-card {
            border-radius: 16px;
            padding: 25px;
            color: var(--text-dark);
            position: relative;
            overflow: hidden;
            transition: transform 0.3s ease;
        }

        .stat-card:hover { transform: translateY(-5px); }
        .stat-card-1 { background: linear-gradient(135deg, #FFD700, #FFA500); }
        .stat-card-2 { background: linear-gradient(135deg, #FFE566, #FFD700); }
        .stat-card-3 { background: linear-gradient(135deg, #FFA500, #FF8C00); }
        .stat-card-4 { background: linear-gradient(135deg, #FFCC00, #FFB300); }

        .stat-card .stat-icon {
            font-size: 3rem;
            opacity: 0.3;
            position: absolute;
            right: 20px;
            top: 50%;
            transform: translateY(-50%);
        }

        .stat-card .stat-number { font-size: 2.5rem; font-weight: 800; }
        .stat-card .stat-label { font-size: 0.9rem; font-weight: 600; opacity: 0.8; }

        /* BUTTONS */
        .btn-primary {
            background: linear-gradient(135deg, #FFD700, #FFA500);
            border: none;
            color: var(--text-dark);
            font-weight: 600;
            border-radius: 10px;
            padding: 10px 24px;
            transition: all 0.3s ease;
        }

        .btn-primary:hover {
            background: linear-gradient(135deg, #FFA500, #FF8C00);
            color: var(--text-dark);
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(255,165,0,0.4);
        }

        .btn-warning {
            background: linear-gradient(135deg, #FFE566, #FFD700);
            border: none;
            color: var(--text-dark);
            font-weight: 600;
            border-radius: 10px;
        }

        .btn-danger { border-radius: 10px; font-weight: 600; }
        .btn-success { border-radius: 10px; font-weight: 600; }
        .btn-info { border-radius: 10px; font-weight: 600; }

        .btn-outline-primary {
            border: 2px solid #FFA500;
            color: #FFA500;
            border-radius: 10px;
            font-weight: 600;
        }

        .btn-outline-primary:hover {
            background: linear-gradient(135deg, #FFD700, #FFA500);
            color: var(--text-dark);
            border-color: #FFD700;
        }

        /* TABLES */
        .table-yellow thead {
            background: linear-gradient(135deg, #FFD700, #FFA500);
            color: var(--text-dark);
        }

        .table-yellow thead th { font-weight: 700; padding: 14px; border: none; }
        .table-yellow tbody tr { transition: background-color 0.2s; }
        .table-yellow tbody tr:hover { background-color: var(--yellow-light); }
        .table-yellow tbody td { padding: 12px 14px; vertical-align: middle; }

        /* FORMS */
        .form-control, .form-select {
            border: 2px solid #FFE566;
            border-radius: 10px;
            padding: 10px 15px;
            transition: border-color 0.3s, box-shadow 0.3s;
        }

        .form-control:focus, .form-select:focus {
            border-color: #FFA500;
            box-shadow: 0 0 0 0.2rem rgba(255,165,0,0.25);
        }

        .form-label { font-weight: 600; color: var(--brown-dark); }

        /* BADGES */
        .badge-booked { background-color: #FFD700; color: var(--text-dark); }
        .badge-completed { background-color: #28a745; color: #fff; }
        .badge-cancelled { background-color: #dc3545; color: #fff; }
        .badge-paid { background-color: #28a745; color: #fff; }
        .badge-unpaid { background-color: #FFA500; color: var(--text-dark); }

        /* PAGE HEADER */
        .page-header {
            background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
            border-radius: 16px;
            padding: 25px 30px;
            margin-bottom: 25px;
            color: var(--text-dark);
            box-shadow: 0 4px 15px rgba(255,165,0,0.3);
        }

        .page-header h2 { font-weight: 800; margin: 0; }
        .page-header p { margin: 5px 0 0; opacity: 0.8; }

        /* ALERTS */
        .alert-success { background: #d4edda; border-color: #28a745; border-radius: 12px; }
        .alert-danger { background: #f8d7da; border-color: #dc3545; border-radius: 12px; }
        .alert-warning { background: var(--yellow-light); border-color: #FFA500; border-radius: 12px; }

        /* FOOTER */
        footer {
            background: linear-gradient(135deg, #FF8C00, #FFD700);
            color: var(--text-dark);
            text-align: center;
            padding: 20px;
            margin-top: 40px;
            font-weight: 600;
        }

        /* MAIN CONTENT */
        .main-content { padding: 30px; }

        /* SCROLLBAR */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: var(--yellow-pale); }
        ::-webkit-scrollbar-thumb { background: #FFA500; border-radius: 4px; }

        /* BREADCRUMB */
        .breadcrumb { background: transparent; padding: 0; margin-bottom: 10px; }
        .breadcrumb-item a { color: #FFA500; text-decoration: none; font-weight: 600; }
        .breadcrumb-item.active { color: var(--brown-dark); }

        /* SEARCH BOX */
        .search-box {
            background: var(--yellow-light);
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 20px;
            border: 2px solid #FFE566;
        }
    </style>
</head>
<body>
    <!-- TOP NAVBAR -->
    <nav class="navbar navbar-expand-lg">
        <div class="container-fluid px-4">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <i class="fas fa-hospital-alt"></i> MediCare
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <span class="nav-link">
                                <i class="fas fa-user-circle"></i>
                                @User.Identity.Name
                                <span class="badge ms-1" style="background:#fff;color:#FF8C00;">
                                    @User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                                </span>
                            </span>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Auth" asp-action="Logout">
                                <i class="fas fa-sign-out-alt"></i> Logout
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Auth" asp-action="Login">
                                <i class="fas fa-sign-in-alt"></i> Login
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Auth" asp-action="Register">
                                <i class="fas fa-user-plus"></i> Register
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="container-fluid">
        <div class="row">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <!-- SIDEBAR -->
                <div class="col-md-2 px-0 sidebar">
                    <nav class="nav flex-column pt-2">
                        <span class="sidebar-heading">Main</span>
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="fas fa-tachometer-alt"></i> Dashboard
                        </a>

                        <span class="sidebar-heading">Hospital</span>
                        <a class="nav-link" asp-controller="Departments" asp-action="Index">
                            <i class="fas fa-building"></i> Departments
                        </a>
                        <a class="nav-link" asp-controller="Doctors" asp-action="Index">
                            <i class="fas fa-user-md"></i> Doctors
                        </a>

                        <span class="sidebar-heading">Patients</span>
                        <a class="nav-link" asp-controller="Appointments" asp-action="Index">
                            <i class="fas fa-calendar-check"></i> Appointments
                        </a>
                        <a class="nav-link" asp-controller="Prescriptions" asp-action="Index">
                            <i class="fas fa-prescription-bottle-alt"></i> Prescriptions
                        </a>
                        <a class="nav-link" asp-controller="Bills" asp-action="Index">
                            <i class="fas fa-file-invoice-dollar"></i> Bills
                        </a>

                        @if (User.IsInRole("Admin"))
                        {
                            <span class="sidebar-heading">Admin</span>
                            <a class="nav-link" asp-controller="Auth" asp-action="Users">
                                <i class="fas fa-users"></i> Manage Users
                            </a>
                        }
                    </nav>
                </div>

                <!-- MAIN CONTENT -->
                <div class="col-md-10 main-content">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show">
                            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show">
                            <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }
                    @RenderBody()
                </div>
            }
            else
            {
                <div class="col-12">
                    @RenderBody()
                </div>
            }
        </div>
    </div>

    <footer>
        <i class="fas fa-hospital-alt me-2"></i>
        MediCare Hospital Management System &copy; @DateTime.Now.Year — Built with ❤️ using ASP.NET Core
    </footer>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>