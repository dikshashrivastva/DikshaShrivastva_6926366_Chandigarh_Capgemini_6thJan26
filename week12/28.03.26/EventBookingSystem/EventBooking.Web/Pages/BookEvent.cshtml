@page "{id:int}"
@model EventBooking.Web.Pages.BookEventModel
@{
    ViewData["Title"] = "Book Tickets";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="auth-card">
            <h2 class="text-center mb-1">Book Tickets 🎫</h2>
            <p class="text-center text-muted mb-4">Secure your seats now</p>

            <div id="loadingEvent" class="text-center py-3">
                <div class="spinner-border" style="color:#81c784" role="status"></div>
            </div>

            <div id="eventDetails" style="display:none">
                <div class="card border-0 mb-4" style="background:#f9fbe7; border-radius:12px;">
                    <div class="card-body">
                        <h5 id="eventTitle" class="fw-bold" style="color:#4caf50"></h5>
                        <p class="mb-1"><i class="bi bi-geo-alt-fill" style="color:#f48fb1"></i> <span id="eventLocation"></span></p>
                        <p class="mb-1"><i class="bi bi-calendar-event" style="color:#f48fb1"></i> <span id="eventDate"></span></p>
                        <p class="mb-1"><i class="bi bi-currency-rupee" style="color:#f48fb1"></i> <span id="eventPrice"></span> per seat</p>
                        <p class="mb-0"><i class="bi bi-people-fill" style="color:#f48fb1"></i> <span id="eventSeats"></span> seats available</p>
                    </div>
                </div>

                <div id="errorMsg" class="alert alert-danger d-none"></div>
                <div id="successMsg" class="alert alert-success d-none"></div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Number of Seats</label>
                    <input type="number" id="seatsInput" class="form-control"
                        min="1" max="10" value="1" onchange="updateTotal()" />
                    <small class="text-muted">Maximum 10 seats per booking</small>
                </div>

                <div class="mb-4 p-3 rounded" style="background:#fce4ec;">
                    <div class="d-flex justify-content-between fw-bold">
                        <span>Total Amount:</span>
                        <span id="totalAmount" style="color:#e91e63">₹0</span>
                    </div>
                </div>

                <button class="btn btn-primary w-100" onclick="confirmBooking()">
                    Confirm Booking
                </button>
                <a href="/" class="btn btn-outline-secondary w-100 mt-2">Back to Events</a>
            </div>
        </div>
    </div>
</div>