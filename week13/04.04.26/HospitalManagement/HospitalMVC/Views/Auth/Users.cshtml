@model List<HospitalMVC.Models.UserViewModel>
@{ ViewData["Title"] = "Manage Users"; }

<div class="page-header">
    <h2><i class="fas fa-users me-3"></i>Manage Users</h2>
    <p>View and manage all registered users in the system.</p>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="fas fa-list me-2"></i>All Users (@Model.Count)</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-yellow table-hover mb-0">
                <thead>
                    <tr>
                        <th>#</th><th>Full Name</th><th>Email</th>
                        <th>Role</th><th>Registered</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>@user.UserId</td>
                            <td><i class="fas fa-user-circle me-2" style="color:#FFA500"></i>@user.FullName</td>
                            <td>@user.Email</td>
                            <td>
                                <span class="badge @(user.Role == "Admin" ? "bg-danger" : user.Role == "Doctor" ? "badge-booked" : "badge-completed") px-3 py-2">
                                    @user.Role
                                </span>
                            </td>
                            <td>@user.CreatedAt.ToString("MMM dd, yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>