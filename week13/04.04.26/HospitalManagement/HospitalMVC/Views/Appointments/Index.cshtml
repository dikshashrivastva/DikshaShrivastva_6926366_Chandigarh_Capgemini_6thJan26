@model List<HospitalMVC.Models.AppointmentViewModel>
@{ ViewData["Title"] = "Appointments"; }

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2><i class="fas fa-calendar-check me-3"></i>Appointments</h2>
        <p>Manage and track all hospital appointments.</p>
    </div>
    @if (User.IsInRole("Patient"))
    {
        <a asp-action="Book" class="btn btn-primary btn-lg">
            <i class="fas fa-plus me-2"></i>Book Appointment
        </a>
    }
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="fas fa-list me-2"></i>All Appointments (@Model.Count)</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-yellow table-hover mb-0">
                <thead>
                    <tr>
                        <th>#</th><th>Patient</th><th>Doctor</th>
                        <th>Department</th><th>Date & Time</th>
                        <th>Status</th><th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in Model)
                    {
                        <tr>
                            <td>@a.AppointmentId</td>
                            <td><i class="fas fa-user me-2" style="color:#FFA500"></i>@a.PatientName</td>
                            <td><i class="fas fa-user-md me-2" style="color:#FFA500"></i>Dr. @a.DoctorName</td>
                            <td>@a.DepartmentName</td>
                            <td>
                                <i class="fas fa-calendar me-1" style="color:#FFA500"></i>
                                @a.AppointmentDate.ToString("MMM dd, yyyy")<br/>
                                <small class="text-muted">@a.AppointmentDate.ToString("hh:mm tt")</small>
                            </td>
                            <td>
                                <span class="badge px-3 py-2 badge-@a.Status.ToLower()">
                                    @a.Status
                                </span>
                            </td>
                            <td>
                                <div class="d-flex gap-1 flex-wrap">
                                    @if (User.IsInRole("Admin") || User.IsInRole("Doctor"))
                                    {
                                        @if (a.Status == "Booked")
                                        {
                                            <a asp-action="UpdateStatus"
                                               asp-route-id="@a.AppointmentId"
                                               asp-route-status="Completed"
                                               class="btn btn-success btn-sm">
                                                <i class="fas fa-check"></i>
                                            </a>
                                        }
                                        <a asp-controller="Prescriptions" asp-action="Create"
                                           asp-route-appointmentId="@a.AppointmentId"
                                           class="btn btn-info btn-sm">
                                            <i class="fas fa-prescription-bottle-alt"></i>
                                        </a>
                                        <a asp-controller="Bills" asp-action="Create"
                                           asp-route-appointmentId="@a.AppointmentId"
                                           class="btn btn-warning btn-sm">
                                            <i class="fas fa-file-invoice-dollar"></i>
                                        </a>
                                    }
                                    @if (a.Status == "Booked")
                                    {
                                        <a asp-action="Cancel" asp-route-id="@a.AppointmentId"
                                           class="btn btn-danger btn-sm"
                                           onclick="return confirm('Cancel this appointment?')">
                                            <i class="fas fa-times"></i>
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="fas fa-calendar-times fa-4x mb-3" style="color:#FFD700;opacity:0.5;"></i>
                <h5 class="text-muted">No appointments found.</h5>
                @if (User.IsInRole("Patient"))
                {
                    <a asp-action="Book" class="btn btn-primary mt-2">Book Your First Appointment</a>
                }
            </div>
        }
    </div>
</div>